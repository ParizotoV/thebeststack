{
  "name": "thebeststack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @thebeststack/db db:push",
    "db:studio": "turbo -F @thebeststack/db db:studio",
    "db:generate": "turbo -F @thebeststack/db db:generate",
    "db:migrate": "turbo -F @thebeststack/db db:migrate",
    "db:start": "turbo -F @thebeststack/db db:start",
    "db:watch": "turbo -F @thebeststack/db db:watch",
    "db:stop": "turbo -F @thebeststack/db db:stop",
    "db:down": "turbo -F @thebeststack/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@thebeststack/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tanstack/eslint-plugin-query": "^5.100.9",
    "@thebeststack/config": "workspace:*",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-cypress": "^6.4.1",
    "eslint-plugin-github": "6.0.0",
    "eslint-plugin-html": "^8.1.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-n": "^18.0.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-storybook": "^10.3.6",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "husky": "latest",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "stylelint": "latest",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "ultracite": "7.7.0"
  },
  "packageManager": "pnpm@10.33.2"
}
